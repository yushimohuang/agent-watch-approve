# ===========================
# Server
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# CORS
# ===========================
CORS_ORIGINS=*

# ===========================
# Database (PostgreSQL)
# ===========================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=agentwatch

# ===========================
# Redis
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================
# JWT
# ===========================
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ===========================
# 飞书 (Feishu / Lark) - 唯一推送通道
# ===========================
# 申请地址：https://open.feishu.cn/
# 步骤：
#   1. 注册飞书开放平台 → 创建自建应用 → 启用机器人 + 事件订阅
#   2. 拿 App ID / App Secret / Verification Token / Encrypt Key
#   3. 配 Cloudflare Tunnel 暴露 webhook（见下方 PUBLIC_URL）
#   4. 在飞书开放平台配置事件订阅 URL: {PUBLIC_URL}/webhook/feishu
FEISHU_ENABLED=true
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=your_verification_token
FEISHU_ENCRYPT_KEY=your_encrypt_key
FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis

# 飞书用户 open_id 映射（可选 - 用于绑定 userId → 飞书 open_id）
# 格式：{"user_abc123": "ou_xxxxxxxxxxxx"}
# 你可以登录飞书 Open API 自己查 open_id，或让用户扫机器人二维码获取
FEISHU_USER_OPEN_ID_MAP={}

# 公网 URL（飞书 webhook 回调用）
# 方式1: Cloudflare Tunnel（推荐，免费）
#   cloudflared tunnel --url http://localhost:3000
# 方式2: ngrok
#   ngrok http 3000
# 拿到地址后填入：
PUBLIC_URL=http://localhost:3000

# Dashboard URL（飞书卡片"查看详情"按钮跳转地址）
DASHBOARD_URL=http://localhost:3001

# ===========================
# Dashboard 公网访问密码（公网暴露时必填）
# ===========================
# 当 PUBLIC_URL 不是 localhost 时，必须设置此密码才能访问 Dashboard
# 留空 = 拒绝公网访问（503）
# 建议: openssl rand -hex 16
DASHBOARD_PASSWORD=

# ===========================
# 本地用户名（首次启动时使用，默认 'local-user'）
# ===========================
LOCAL_USER_NAME=local-user

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# ===========================
# Approval
# ===========================
APPROVAL_TIMEOUT=300
