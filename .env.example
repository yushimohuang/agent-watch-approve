# Agent Watch API
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=agentwatch

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
# [v2.1 安全] 生产环境必须 32+ 字符，建议: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production-must-be-32+chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Approval Defaults
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Approval Defaults
APPROVAL_TIMEOUT=300

# CORS
CORS_ORIGINS=*
